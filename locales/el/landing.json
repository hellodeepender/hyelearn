  "planFreePrice": "$0",
  "planFreePeriod": "\u0394\u03C9\u03C1\u03B5\u03AC\u03BD \u03B3\u03B9\u03B1 \u03C0\u03AC\u03BD\u03C4\u03B1",
  "planFreeFeature1": "\u039C\u03B1\u03B8\u03AE\u03BC\u03B1\u03C4\u03B1 \u03BD\u03B7\u03C0\u03B9\u03B1\u03B3\u03C9\u03B3\u03B5\u03AF\u03BF\u03C5",
  "planFreeFeature2": "\u0392\u03B1\u03C3\u03B9\u03BA\u03AE \u03C0\u03C1\u03CC\u03C3\u03B2\u03B1\u03C3\u03B7",
  "planFreeFeature3": "\u03A0\u03B1\u03C1\u03B1\u03BA\u03BF\u03BB\u03BF\u03CD\u03B8\u03B7\u03C3\u03B7 \u03C0\u03C1\u03BF\u03CC\u03B4\u03BF\u03C5",
  "planPaidTitle": "\u03A0\u03BB\u03AE\u03C1\u03B7\u03C2 \u03A0\u03C1\u03CC\u03C3\u03B2\u03B1\u03C3\u03B7",
  "planPaidPrice": "$9.99",
  "planPaidPeriod": "\u03AE $79.99/\u03AD\u03C4\u03BF\u03C2 (\u03B5\u03BE\u03BF\u03B9\u03BA\u03BF\u03BD\u03CC\u03BC\u03B7\u03C3\u03B7 33%)",
  "planPaidFeature1": "\u03A0\u03BB\u03AE\u03C1\u03B5\u03C2 \u03C0\u03C1\u03CC\u03B3\u03C1\u03B1\u03BC\u03BC\u03B1 K-5",
  "planPaidFeature2": "\u0395\u03C0\u03B9\u03C0\u03BB\u03AD\u03BF\u03BD \u03B5\u03BE\u03AC\u03C3\u03BA\u03B7\u03C3\u03B7 (5 \u03C3\u03C5\u03BD\u03B5\u03B4\u03C1\u03AF\u03B5\u03C2/\u03B7\u03BC\u03AD\u03C1\u03B1)",
  "planPaidFeature3": "\u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC \u03B5\u03BC\u03B2\u03BB\u03AE\u03BC\u03B1\u03C4\u03B1 & \u03B2\u03C1\u03B1\u03B2\u03B5\u03AF\u03B1",
  "planPaidFeature4": "\u0388\u03C9\u03C2 3 \u03C0\u03B1\u03B9\u03B4\u03B9\u03AC",
  "planSchoolTitle": "\u0393\u03B9\u03B1 \u03A3\u03C7\u03BF\u03BB\u03B5\u03AF\u03B1",
  "planSchoolPrice": "\u0395\u03C0\u03B9\u03BA\u03BF\u03B9\u03BD\u03C9\u03BD\u03AE\u03C3\u03C4\u03B5",
  "planSchoolPeriod": "\u0395\u03B9\u03B4\u03B9\u03BA\u03AD\u03C2 \u03C3\u03C7\u03BF\u03BB\u03B9\u03BA\u03AD\u03C2 \u03C4\u03B9\u03BC\u03AD\u03C2",
  "planSchoolFeature1": "\u038C\u03BB\u03B1 \u03B1\u03C0\u03CC \u03C4\u03B7\u03BD \u03A0\u03BB\u03AE\u03C1\u03B7 \u03A0\u03C1\u03CC\u03C3\u03B2\u03B1\u03C3\u03B7",
  "planSchoolFeature2": "\u0391\u03C0\u03B5\u03C1\u03B9\u03CC\u03C1\u03B9\u03C3\u03C4\u03BF\u03B9 \u03BC\u03B1\u03B8\u03B7\u03C4\u03AD\u03C2",
  "planSchoolFeature3": "\u03A0\u03AF\u03BD\u03B1\u03BA\u03B5\u03C2 \u03B5\u03BB\u03AD\u03B3\u03C7\u03BF\u03C5 \u03B4\u03B1\u03C3\u03BA\u03AC\u03BB\u03C9\u03BD",
  "planSchoolFeature4": "\u0394\u03B9\u03B1\u03C7\u03B5\u03AF\u03C1\u03B9\u03C3\u03B7 \u03C4\u03AC\u03BE\u03B7\u03C2",
  "mostPopular": "\u0394\u03B7\u03BC\u03BF\u03C6\u03B9\u03BB\u03AD\u03C3\u03C4\u03B5\u03C1\u03BF",

  "faqTitle": "\u0395\u03C1\u03C9\u03C4\u03AE\u03C3\u03B5\u03B9\u03C2 \u03B3\u03BF\u03BD\u03AD\u03C9\u03BD",
  "faq1Q": "\u03A0\u03BF\u03B9\u03B1 \u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC \u03B4\u03B9\u03B4\u03AC\u03C3\u03BA\u03BF\u03BD\u03C4\u03B1\u03B9;",
  "faq1A": "\u039D\u03AD\u03B1 \u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC \u2014 \u03B7 \u03AF\u03B4\u03B9\u03B1 \u03B3\u03BB\u03CE\u03C3\u03C3\u03B1 \u03C0\u03BF\u03C5 \u03BC\u03B1\u03B8\u03B1\u03AF\u03BD\u03BF\u03C5\u03BD \u03C4\u03B1 \u03C0\u03B1\u03B9\u03B4\u03B9\u03AC \u03C3\u03C4\u03B1 \u03B5\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC \u03C3\u03C7\u03BF\u03BB\u03B5\u03AF\u03B1 \u03C4\u03B7\u03C2 \u03B4\u03B9\u03B1\u03C3\u03C0\u03BF\u03C1\u03AC\u03C2.",
  "faq2Q": "\u0393\u03B9\u03B1 \u03C0\u03BF\u03B9\u03B5\u03C2 \u03B7\u03BB\u03B9\u03BA\u03AF\u03B5\u03C2 \u03B5\u03AF\u03BD\u03B1\u03B9;",
  "faq2A": "\u039D\u03B7\u03C0\u03B9\u03B1\u03B3\u03C9\u03B3\u03B5\u03AF\u03BF \u03AD\u03C9\u03C2 \u0395\u0384 \u0394\u03B7\u03BC\u03BF\u03C4\u03B9\u03BA\u03BF\u03CD. \u03A0\u03C1\u03BF\u03C3\u03B8\u03AD\u03C4\u03BF\u03C5\u03BC\u03B5 \u03BD\u03AD\u03B1 \u03B5\u03C0\u03AF\u03C0\u03B5\u03B4\u03B1 \u03C4\u03B1\u03BA\u03C4\u03B9\u03BA\u03AC.",
  "faq3Q": "\u03A7\u03C1\u03B5\u03B9\u03AC\u03B6\u03B5\u03C4\u03B1\u03B9 \u03BD\u03B1 \u03BC\u03B9\u03BB\u03AC\u03C9 \u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC \u03B3\u03B9\u03B1 \u03BD\u03B1 \u03B2\u03BF\u03B7\u03B8\u03AE\u03C3\u03C9;",
  "faq3A": "\u038C\u03C7\u03B9! \u0397 \u03C0\u03BB\u03B1\u03C4\u03C6\u03CC\u03C1\u03BC\u03B1 \u03BA\u03B1\u03B8\u03BF\u03B4\u03B7\u03B3\u03B5\u03AF \u03C4\u03BF \u03C0\u03B1\u03B9\u03B4\u03AF \u03C3\u03B5 \u03BA\u03AC\u03B8\u03B5 \u03BC\u03AC\u03B8\u03B7\u03BC\u03B1. \u03A5\u03C0\u03AC\u03C1\u03C7\u03BF\u03C5\u03BD \u03C5\u03C0\u03BF\u03B4\u03B5\u03AF\u03BE\u03B5\u03B9\u03C2 \u03C3\u03C4\u03B1 \u0391\u03B3\u03B3\u03BB\u03B9\u03BA\u03AC \u03CC\u03C4\u03B1\u03BD \u03C7\u03C1\u03B5\u03B9\u03AC\u03B6\u03B5\u03C4\u03B1\u03B9.",
  "faq4Q": "\u0395\u03AF\u03BD\u03B1\u03B9 \u03B1\u03C3\u03C6\u03B1\u03BB\u03AD\u03C2 \u03B3\u03B9\u03B1 \u03C0\u03B1\u03B9\u03B4\u03B9\u03AC;",
  "faq4A": "\u0391\u03C0\u03BF\u03BB\u03CD\u03C4\u03C9\u03C2. \u03A7\u03C9\u03C1\u03AF\u03C2 \u03B4\u03B9\u03B1\u03C6\u03B7\u03BC\u03AF\u03C3\u03B5\u03B9\u03C2, \u03C7\u03C9\u03C1\u03AF\u03C2 \u03BA\u03BF\u03B9\u03BD\u03C9\u03BD\u03B9\u03BA\u03AC \u03B4\u03AF\u03BA\u03C4\u03C5\u03B1, \u03C7\u03C9\u03C1\u03AF\u03C2 \u03B5\u03BE\u03C9\u03C4\u03B5\u03C1\u03B9\u03BA\u03BF\u03CD\u03C2 \u03C3\u03C5\u03BD\u03B4\u03AD\u03C3\u03BC\u03BF\u03C5\u03C2. \u03A4\u03BF \u03C0\u03B1\u03B9\u03B4\u03AF \u03B2\u03BB\u03AD\u03C0\u03B5\u03B9 \u03BC\u03CC\u03BD\u03BF \u03B5\u03BA\u03C0\u03B1\u03B9\u03B4\u03B5\u03C5\u03C4\u03B9\u03BA\u03CC \u03C0\u03B5\u03C1\u03B9\u03B5\u03C7\u03CC\u03BC\u03B5\u03BD\u03BF.",
  "faq5Q": "\u03A0\u03CE\u03C2 \u03B4\u03B7\u03BC\u03B9\u03BF\u03C5\u03C1\u03B3\u03B5\u03AF\u03C4\u03B1\u03B9 \u03C4\u03BF \u03C0\u03C1\u03CC\u03B3\u03C1\u03B1\u03BC\u03BC\u03B1;",
  "faq5A": "\u03A4\u03BF \u03C0\u03C1\u03CC\u03B3\u03C1\u03B1\u03BC\u03BC\u03B1 \u03C3\u03C7\u03B5\u03B4\u03B9\u03AC\u03B6\u03B5\u03C4\u03B1\u03B9 \u03B3\u03B9\u03B1 \u03BC\u03B1\u03B8\u03B7\u03C4\u03AD\u03C2 \u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03CE\u03BD \u03BA\u03B1\u03B9 \u03B4\u03BF\u03BC\u03B5\u03AF\u03C4\u03B1\u03B9 \u03C0\u03C1\u03BF\u03BF\u03B4\u03B5\u03C5\u03C4\u03B9\u03BA\u03AC \u03B1\u03C0\u03CC \u03C4\u03BF \u03B1\u03BB\u03C6\u03AC\u03B2\u03B7\u03C4\u03BF \u03BC\u03AD\u03C7\u03C1\u03B9 \u03C4\u03B7\u03BD \u03BA\u03B1\u03C4\u03B1\u03BD\u03CC\u03B7\u03C3\u03B7 \u03BA\u03B5\u03B9\u03BC\u03AD\u03BD\u03BF\u03C5. \u03A4\u03BF \u03C0\u03B5\u03C1\u03B9\u03B5\u03C7\u03CC\u03BC\u03B5\u03BD\u03BF \u03B5\u03BB\u03AD\u03B3\u03C7\u03B5\u03C4\u03B1\u03B9 \u03B1\u03C0\u03CC \u0388\u03BB\u03BB\u03B7\u03BD\u03B5\u03C2 \u03B5\u03BA\u03C0\u03B1\u03B9\u03B4\u03B5\u03C5\u03C4\u03B9\u03BA\u03BF\u03CD\u03C2.",
  "faq6Q": "\u039C\u03C0\u03BF\u03C1\u03BF\u03CD\u03BD \u03C4\u03B1 \u03C3\u03C7\u03BF\u03BB\u03B5\u03AF\u03B1 \u03BD\u03B1 \u03C4\u03BF \u03C7\u03C1\u03B7\u03C3\u03B9\u03BC\u03BF\u03C0\u03BF\u03B9\u03AE\u03C3\u03BF\u03C5\u03BD;",
  "faq6A": "\u039D\u03B1\u03B9! \u03A0\u03C1\u03BF\u03C3\u03C6\u03AD\u03C1\u03BF\u03C5\u03BC\u03B5 \u03C3\u03C7\u03BF\u03BB\u03B9\u03BA\u03AC \u03C0\u03B1\u03BA\u03AD\u03C4\u03B1 \u03BC\u03B5 \u03C0\u03AF\u03BD\u03B1\u03BA\u03B5\u03C2 \u03B5\u03BB\u03AD\u03B3\u03C7\u03BF\u03C5 \u03BA\u03B1\u03B9 \u03B4\u03B9\u03B1\u03C7\u03B5\u03AF\u03C1\u03B9\u03C3\u03B7 \u03C4\u03AC\u03BE\u03B7\u03C2. \u0395\u03C0\u03B9\u03BA\u03BF\u03B9\u03BD\u03C9\u03BD\u03AE\u03C3\u03C4\u03B5 \u03C3\u03C4\u03BF schools@mathaino.net.",
  "faq7Q": "\u03A0\u03CC\u03C3\u03BF \u03B4\u03B9\u03B1\u03C1\u03BA\u03B5\u03AF \u03BA\u03AC\u03B8\u03B5 \u03BC\u03AC\u03B8\u03B7\u03BC\u03B1;",
  "faq7A": "\u03A0\u03B5\u03C1\u03AF\u03C0\u03BF\u03C5 5 \u03BB\u03B5\u03C0\u03C4\u03AC. \u0391\u03C1\u03BA\u03B5\u03C4\u03AC \u03C3\u03CD\u03BD\u03C4\u03BF\u03BC\u03BF \u03B3\u03B9\u03B1 \u03BA\u03AC\u03B8\u03B5 \u03C1\u03BF\u03C5\u03C4\u03AF\u03BD\u03B1, \u03B1\u03C1\u03BA\u03B5\u03C4\u03AC \u03BC\u03B5\u03B3\u03AC\u03BB\u03BF \u03B3\u03B9\u03B1 \u03C0\u03C1\u03B1\u03B3\u03BC\u03B1\u03C4\u03B9\u03BA\u03AE \u03C0\u03C1\u03CC\u03BF\u03B4\u03BF.",
  "faq8Q": "\u03A0\u03CE\u03C2 \u03BA\u03C1\u03B1\u03C4\u03CE \u03C4\u03BF \u03C0\u03B1\u03B9\u03B4\u03AF \u03BC\u03BF\u03C5 \u03C3\u03C5\u03B3\u03BA\u03B5\u03BD\u03C4\u03C1\u03C9\u03BC\u03AD\u03BD\u03BF;",
  "faq8A": "\u03A7\u03C1\u03B7\u03C3\u03B9\u03BC\u03BF\u03C0\u03BF\u03B9\u03AE\u03C3\u03C4\u03B5 \u03C4\u03B7 \u03BB\u03B5\u03B9\u03C4\u03BF\u03C5\u03C1\u03B3\u03AF\u03B1 \u03B5\u03C3\u03C4\u03AF\u03B1\u03C3\u03B7\u03C2 \u03C4\u03B7\u03C2 \u03C3\u03C5\u03C3\u03BA\u03B5\u03C5\u03AE\u03C2 \u03C3\u03B1\u03C2! \u03A3\u03B5 iPad \u03AE iPhone, \u03B5\u03BD\u03B5\u03C1\u03B3\u03BF\u03C0\u03BF\u03B9\u03AE\u03C3\u03C4\u03B5 \u03C4\u03BF Guided Access (\u03A1\u03C5\u03B8\u03BC\u03AF\u03C3\u03B5\u03B9\u03C2 \u2192 \u03A0\u03C1\u03BF\u03C3\u03B2\u03B1\u03C3\u03B9\u03BC\u03CC\u03C4\u03B7\u03C4\u03B1 \u2192 Guided Access). \u03A3\u03B5 Android, \u03C7\u03C1\u03B7\u03C3\u03B9\u03BC\u03BF\u03C0\u03BF\u03B9\u03AE\u03C3\u03C4\u03B5 \u03C4\u03BF Screen Pinning (\u03A1\u03C5\u03B8\u03BC\u03AF\u03C3\u03B5\u03B9\u03C2 \u2192 \u0391\u03C3\u03C6\u03AC\u03BB\u03B5\u03B9\u03B1).",

  "ctaTitle": "\u03A4\u03BF \u03C4\u03B1\u03BE\u03AF\u03B4\u03B9 \u03C4\u03BF\u03C5 \u03C0\u03B1\u03B9\u03B4\u03B9\u03BF\u03CD \u03C3\u03B1\u03C2 \u03C3\u03C4\u03B1 \u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC \u03BE\u03B5\u03BA\u03B9\u03BD\u03AC \u03C3\u03AE\u03BC\u03B5\u03C1\u03B1",
  "ctaSubtitle": "\u0393\u03AF\u03BD\u03B5\u03C4\u03B5 \u03BC\u03AD\u03C1\u03BF\u03C2 \u03C4\u03C9\u03BD \u03BF\u03B9\u03BA\u03BF\u03B3\u03B5\u03BD\u03B5\u03B9\u03CE\u03BD \u03C4\u03B7\u03C2 \u03B4\u03B9\u03B1\u03C3\u03C0\u03BF\u03C1\u03AC\u03C2 \u03C0\u03BF\u03C5 \u03BA\u03C1\u03B1\u03C4\u03BF\u03CD\u03BD \u03C4\u03B7 \u03B3\u03BB\u03CE\u03C3\u03C3\u03B1 \u03B6\u03C9\u03BD\u03C4\u03B1\u03BD\u03AE.",
