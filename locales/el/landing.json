  "orEmailSchools": "\u0389 \u03C3\u03C4\u03B5\u03AF\u03BB\u03C4\u03B5 email \u03C3\u03C4\u03BF schools@mathaino.net",

  "whyTitle": "\u0393\u03B9\u03B1\u03C4\u03AF Mathaino;",
  "whyDesc": "\u039F\u03B9 \u03B5\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AD\u03C2 \u03BF\u03B9\u03BA\u03BF\u03B3\u03AD\u03BD\u03B5\u03B9\u03B5\u03C2 \u03C3\u03C4\u03B7 \u03B4\u03B9\u03B1\u03C3\u03C0\u03BF\u03C1\u03AC \u03B1\u03BD\u03C4\u03B9\u03BC\u03B5\u03C4\u03C9\u03C0\u03AF\u03B6\u03BF\u03C5\u03BD \u03BC\u03B9\u03B1 \u03BA\u03BF\u03B9\u03BD\u03AE \u03C0\u03C1\u03CC\u03BA\u03BB\u03B7\u03C3\u03B7 \u2014 \u03BD\u03B1 \u03BA\u03C1\u03B1\u03C4\u03AE\u03C3\u03BF\u03C5\u03BD \u03C4\u03B1 \u03C0\u03B1\u03B9\u03B4\u03B9\u03AC \u03C4\u03BF\u03C5\u03C2 \u03C3\u03C5\u03BD\u03B4\u03B5\u03B4\u03B5\u03BC\u03AD\u03BD\u03B1 \u03BC\u03B5 \u03C4\u03B7 \u03B3\u03BB\u03CE\u03C3\u03C3\u03B1 \u03C4\u03BF\u03C5\u03C2. \u039C\u03B5\u03C4\u03B1\u03BE\u03CD \u03C3\u03C7\u03BF\u03BB\u03B5\u03AF\u03BF\u03C5, \u03BC\u03B5\u03BB\u03AD\u03C4\u03B7\u03C2 \u03BA\u03B1\u03B9 \u03B4\u03C1\u03B1\u03C3\u03C4\u03B7\u03C1\u03B9\u03BF\u03C4\u03AE\u03C4\u03C9\u03BD, \u03B4\u03B5\u03BD \u03C5\u03C0\u03AC\u03C1\u03C7\u03B5\u03B9 \u03C0\u03BF\u03C4\u03AD \u03B1\u03C1\u03BA\u03B5\u03C4\u03CC\u03C2 \u03C7\u03C1\u03CC\u03BD\u03BF\u03C2 \u03B3\u03B9\u03B1 \u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC. \u03A4\u03BF Mathaino \u03C6\u03C4\u03B9\u03AC\u03C7\u03C4\u03B7\u03BA\u03B5 \u03B3\u03B9\u03B1 \u03BD\u03B1 \u03BB\u03CD\u03C3\u03B5\u03B9 \u03B1\u03C5\u03C4\u03CC. \u0388\u03BD\u03B1 \u03B4\u03BF\u03BC\u03B7\u03BC\u03AD\u03BD\u03BF, \u03B4\u03B9\u03B1\u03B4\u03C1\u03B1\u03C3\u03C4\u03B9\u03BA\u03CC \u03C0\u03C1\u03CC\u03B3\u03C1\u03B1\u03BC\u03BC\u03B1 \u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03CE\u03BD \u03C0\u03BF\u03C5 \u03BB\u03B5\u03B9\u03C4\u03BF\u03C5\u03C1\u03B3\u03B5\u03AF \u03C3\u03B5 \u03BC\u03CC\u03BB\u03B9\u03C2 5 \u03BB\u03B5\u03C0\u03C4\u03AC \u03C4\u03B7\u03BD \u03B7\u03BC\u03AD\u03C1\u03B1. \u03A3\u03C7\u03B5\u03B4\u03B9\u03B1\u03C3\u03BC\u03AD\u03BD\u03BF \u03BC\u03B5 \u0388\u03BB\u03BB\u03B7\u03BD\u03B5\u03C2 \u03B5\u03BA\u03C0\u03B1\u03B9\u03B4\u03B5\u03C5\u03C4\u03B9\u03BA\u03BF\u03CD\u03C2, \u03BA\u03AC\u03B8\u03B5 \u03BC\u03AC\u03B8\u03B7\u03BC\u03B1 \u03C7\u03C4\u03AF\u03B6\u03B5\u03B9 \u03C0\u03AC\u03BD\u03C9 \u03C3\u03C4\u03BF \u03C0\u03C1\u03BF\u03B7\u03B3\u03BF\u03CD\u03BC\u03B5\u03BD\u03BF \u2014 \u03B1\u03C0\u03CC \u03C4\u03BF \u03B1\u03BB\u03C6\u03AC\u03B2\u03B7\u03C4\u03BF \u03BC\u03AD\u03C7\u03C1\u03B9 \u03C4\u03B7\u03BD \u03BA\u03B1\u03C4\u03B1\u03BD\u03CC\u03B7\u03C3\u03B7 \u03BA\u03B5\u03B9\u03BC\u03AD\u03BD\u03BF\u03C5. \u03A7\u03C9\u03C1\u03AF\u03C2 \u03B2\u03B9\u03B2\u03BB\u03AF\u03B1, \u03C7\u03C9\u03C1\u03AF\u03C2 \u03C0\u03C1\u03BF\u03B3\u03C1\u03B1\u03BC\u03BC\u03B1\u03C4\u03B9\u03C3\u03BC\u03CC. \u0391\u03C0\u03BB\u03AC \u03B1\u03BD\u03BF\u03AF\u03BE\u03C4\u03B5 \u03C4\u03BF, \u03BC\u03AC\u03B8\u03B5\u03C4\u03B5 \u03BC\u03B1\u03B6\u03AF \u03BA\u03B1\u03B9 \u03B4\u03B5\u03AF\u03C4\u03B5 \u03C4\u03B1 \u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC \u03C4\u03BF\u03C5 \u03C0\u03B1\u03B9\u03B4\u03B9\u03BF\u03CD \u03C3\u03B1\u03C2 \u03BD\u03B1 \u03B1\u03BD\u03B1\u03C0\u03C4\u03CD\u03C3\u03C3\u03BF\u03BD\u03C4\u03B1\u03B9.",
  "whatMakesDifferentTitle": "\u03A4\u03B9 \u03BA\u03AC\u03BD\u03B5\u03B9 \u03C4\u03BF Mathaino \u03B4\u03B9\u03B1\u03C6\u03BF\u03C1\u03B5\u03C4\u03B9\u03BA\u03CC;",
  "diff1Title": "\u03A6\u03C4\u03B9\u03B1\u03B3\u03BC\u03AD\u03BD\u03BF \u03B3\u03B9\u03B1 \u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC \u03C4\u03B7\u03C2 \u03B4\u03B9\u03B1\u03C3\u03C0\u03BF\u03C1\u03AC\u03C2",
  "diff1Desc": "\u038C\u03C7\u03B9 \u03BC\u03B5\u03C4\u03AC\u03C6\u03C1\u03B1\u03C3\u03B7, \u03B1\u03BB\u03BB\u03AC \u03B5\u03B9\u03B4\u03B9\u03BA\u03AC \u03C3\u03C7\u03B5\u03B4\u03B9\u03B1\u03C3\u03BC\u03AD\u03BD\u03BF \u03C0\u03C1\u03CC\u03B3\u03C1\u03B1\u03BC\u03BC\u03B1. \u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC \u03CC\u03C0\u03C9\u03C2 \u03C4\u03B1 \u03BC\u03B1\u03B8\u03B1\u03AF\u03BD\u03BF\u03C5\u03BD \u03C3\u03C4\u03B1 \u03C3\u03C7\u03BF\u03BB\u03B5\u03AF\u03B1 \u03C4\u03B7\u03C2 \u03B4\u03B9\u03B1\u03C3\u03C0\u03BF\u03C1\u03AC\u03C2.",
  "diff2Title": "\u0395\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03CC\u03C2 \u03C0\u03BF\u03BB\u03B9\u03C4\u03B9\u03C3\u03BC\u03CC\u03C2 \u03C3\u03B5 \u03BA\u03AC\u03B8\u03B5 \u03BC\u03AC\u03B8\u03B7\u03BC\u03B1",
  "diff2Desc": "\u039A\u03B5\u03C1\u03B4\u03AF\u03C3\u03C4\u03B5 \u03B5\u03BC\u03B2\u03BB\u03AE\u03BC\u03B1\u03C4\u03B1 \u03BC\u03B5 \u03B5\u03BB\u03BB\u03B7\u03BD\u03B9\u03BA\u03AC \u03BF\u03C1\u03CC\u03C3\u03B7\u03BC\u03B1. \u0391\u03BD\u03B5\u03B2\u03B5\u03AF\u03C4\u03B5 \u03C4\u03BF\u03BD \u038C\u03BB\u03C5\u03BC\u03C0\u03BF \u03BA\u03B1\u03B8\u03CE\u03C2 \u03C0\u03C1\u03BF\u03C7\u03C9\u03C1\u03AC\u03C4\u03B5. \u039C\u03AC\u03B8\u03B5\u03C4\u03B5 \u03BC\u03AD\u03C3\u03B1 \u03B1\u03C0\u03CC \u03C0\u03BF\u03BB\u03B9\u03C4\u03B9\u03C3\u03C4\u03B9\u03BA\u03AC \u03C3\u03B7\u03BC\u03B1\u03BD\u03C4\u03B9\u03BA\u03CC \u03C0\u03B5\u03C1\u03B9\u03B5\u03C7\u03CC\u03BC\u03B5\u03BD\u03BF.",
  "diff3Title": "\u0393\u03B9\u03B1 \u03B1\u03C0\u03B1\u03C3\u03C7\u03BF\u03BB\u03B7\u03BC\u03AD\u03BD\u03B5\u03C2 \u03BF\u03B9\u03BA\u03BF\u03B3\u03AD\u03BD\u03B5\u03B9\u03B5\u03C2",
  "diff3Desc": "\u0391\u03C1\u03BA\u03BF\u03CD\u03BD 5 \u03BB\u03B5\u03C0\u03C4\u03AC \u03C4\u03B7\u03BD \u03B7\u03BC\u03AD\u03C1\u03B1. \u039B\u03B5\u03B9\u03C4\u03BF\u03C5\u03C1\u03B3\u03B5\u03AF \u03C3\u03B5 \u03BA\u03AC\u03B8\u03B5 \u03C3\u03C5\u03C3\u03BA\u03B5\u03C5\u03AE \u2014 \u03C4\u03B7\u03BB\u03AD\u03C6\u03C9\u03BD\u03BF, tablet \u03AE laptop. \u03A7\u03C9\u03C1\u03AF\u03C2 \u03C1\u03B1\u03BD\u03C4\u03B5\u03B2\u03BF\u03CD, \u03C7\u03C9\u03C1\u03AF\u03C2 \u03BC\u03B5\u03C4\u03B1\u03BA\u03B9\u03BD\u03AE\u03C3\u03B5\u03B9\u03C2.",

  "pricingTitle": "\u0391\u03C0\u03BB\u03AD\u03C2 \u03C4\u03B9\u03BC\u03AD\u03C2",
  "pricingSubtitle": "\u039E\u03B5\u03BA\u03B9\u03BD\u03AE\u03C3\u03C4\u03B5 \u03B4\u03C9\u03C1\u03B5\u03AC\u03BD. \u0391\u03BD\u03B1\u03B2\u03B1\u03B8\u03BC\u03AF\u03C3\u03C4\u03B5 \u03CC\u03C4\u03B1\u03BD \u03B5\u03AF\u03C3\u03C4\u03B5 \u03AD\u03C4\u03BF\u03B9\u03BC\u03BF\u03B9.",
